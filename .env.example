# Qwen/DashScope API key — get one at https://home.qwencloud.com/api-keys
# Without this, the app runs in mock mode (QWEN_MOCK=1 implied)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# Base URL for the API endpoint:
#   - International accounts: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   - Mainland China accounts: https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model to use (default: qwen-plus)
# QWEN_MODEL=qwen-plus

# Set to 1 to force mock mode even if DASHSCOPE_API_KEY is set
# QWEN_MOCK=0

# Where EXECUTE notifications are POSTed. The payload auto-formats for
# Slack, Discord or Teams based on the hostname; generic JSON otherwise.
# Leave unset to print notifications to stdout instead.
# WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX

# SQLite path for investigation history, alerts, and "Watch a source"
# observations (memory.py). Default ":memory:" — nothing persists across
# restarts. Set a file path to keep history durable.
# PROBATIO_DB=/data/prove-or-abstain.db

# Requests per minute per client IP, every route except /health
# (ratelimit.py — a single-instance in-memory guard). Default 60.
# RATE_LIMIT_PER_MINUTE=60

# Python logging level for the app's own log output. Default INFO.
# LOG_LEVEL=INFO
