# Qwen/DashScope API key — get one at https://home.qwencloud.com/api-keys
# Without this, the app runs in mock mode (QWEN_MOCK=1 implied)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# Base URL for the API endpoint:
#   - International accounts: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   - Mainland China accounts: https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model to use (default: qwen-plus)
# QWEN_MODEL=qwen-plus

# Set to 1 to force mock mode even if DASHSCOPE_API_KEY is set
# QWEN_MOCK=0
